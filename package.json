{
  "name": "graphknowledgemanager",
  "version": "1.0.4",
  "description": "A web-app tool to help organize your life. With 3-D Graph structure store even the most complex information with incredible ease of use",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "FOR /L %N IN (1,0,2) DO npm run start",
    "start": "npm run copyjs && npm run copycss && npm run copytemplate && npm run copyIndex",
    "copyjs": "copy \"Scripts\\*.*\" \"GraphKnowledgeServer\\GK.Server\\wwwroot\\Scripts\" /Y",
    "copycss": "copy \"Content\\*.*\" \"GraphKnowledgeServer\\GK.Server\\wwwroot\\Content\" /Y",
    "copytemplate": "copy \"*.tmp.html\" \"GraphKnowledgeServer\\GK.Server\\wwwroot\\Templates\" /Y && copy \"mainpanels.tmp1.html\" \"GraphKnowledgeServer\\GK.Server\\wwwroot\\Templates\\mainpanels.tmp1.html\" /Y",
    "copyIndex": "copy index.html \"GraphKnowledgeServer\\GK.Server\\wwwroot\\index.html\" /Y"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pheeca/GraphKnowledgeManager.git"
  },
  "keywords": [
    "design-systems",
    "design",
    "design-tools",
    "meaningful",
    "data",
    "data-populator",
    "data",
    "utilities",
    "todo",
    "data-management"
  ],
  "author": "pheeca",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/pheeca/GraphKnowledgeManager/issues"
  },
  "homepage": "https://github.com/pheeca/GraphKnowledgeManager#readme",
  "devDependencies": {
    "moment": "^2.30.1",
    "vis-network": "^10.0.2",
    "vis-timeline": "^8.5.0"
  }
}
